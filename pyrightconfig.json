{
  "typeCheckingMode": "off",
  "reportGeneralTypeIssues": "none",
  "reportOptionalOperand": "none",
  "reportArgumentType": "none",
  "reportCallIssue": "none",
  "reportAssignmentType": "none",
  "include": [
    "backend"
  ],
  "exclude": [
    "app",
    "frontend",
    "**/node_modules",
    "**/__pycache__",
    "**/.*",
    "**/.venv",
    "**/venv"
  ],
  "executionEnvironments": [
    {
      "root": "backend",
      "extraPaths": [
        "backend"
      ]
    }
  ]
}
